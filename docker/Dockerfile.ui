FROM python:3.11.11-slim AS base
WORKDIR /app
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY shared/ ./shared/

FROM base
COPY ui/ ./ui/
EXPOSE 8080
CMD ["chainlit", "run", "ui/app.py", "--host", "0.0.0.0", "--port", "8080"]
