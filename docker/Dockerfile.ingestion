FROM python:3.11.11-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY shared/    ./shared/
COPY ingestion/ ./ingestion/
COPY config/    ./config/
COPY dataraw/   ./dataraw/

CMD ["python", "ingestion/dag.py"]
