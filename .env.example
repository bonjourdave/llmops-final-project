# OpenAI
OPENAI_API_KEY=

# Zilliz Cloud (Phase 6+)
ZILLIZ_URI=
ZILLIZ_TOKEN=

# Langfuse Cloud
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Vector store backend: "faiss" (Phase 1), "chroma" (Phase 2), "zilliz" (Phase 6)
VECTOR_STORE_BACKEND=faiss

# Active version served (used by serving layer)
ACTIVE_VERSION=v1

# GCP deployment (Phase 7+)
GCP_PROJECT_ID=
REGION=us-central1
REGISTRY=us-central1-docker.pkg.dev/${GCP_PROJECT_ID}/llmops-rag
